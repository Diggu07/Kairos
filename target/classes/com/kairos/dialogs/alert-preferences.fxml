<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER_LEFT" stylesheets="@../styles.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kairos.controller.AlertPreferencesController"
      styleClass="dialog-pane">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Notification Preferences" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -color-text-primary;"/>
    <Separator/>

    <CheckBox fx:id="enableNotificationsCheck" text="Enable Notifications" selected="true" style="-fx-text-fill: -color-text-primary;"/>

    <VBox spacing="5">
        <Label text="Volume" style="-fx-text-fill: -color-text-secondary;"/>
        <Slider fx:id="volumeSlider" min="0" max="100" value="75" showTickMarks="true"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Default Alert Timing" style="-fx-text-fill: -color-text-secondary;"/>
        <ComboBox fx:id="alertTimingCombo" prefWidth="200" styleClass="choice-box"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton" text="Cancel" styleClass="button, button-secondary"/>
        <Button fx:id="saveButton" text="Save Preferences" styleClass="button, button-primary"/>
    </HBox>
</VBox>
