<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
  dashboard.fxml — Main application layout for Kairos.

  Layout:
    ┌──────────┬──────────────────────────────────────┐
    │ Sidebar  │  Top Bar (Search + Filter + New)      │
    │          ├──────────────────────────────────────┤
    │  Nav     │  Content Area (swapped by controller) │
    │          │                                       │
    │          │                                       │
    └──────────┴──────────────────────────────────────┘
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kairos.controller.DashboardController"
            prefWidth="1100" prefHeight="700"
            styleClass="root">

    <!-- ══════════════════════════════════════════════════════════
         LEFT — Sidebar Navigation
         ══════════════════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="root" id="sidebar" spacing="0">

            <!-- App Branding -->
            <Label text="KAIROS" id="appTitle" />
            <Label text="Master the Opportune" id="appSubtitle" />

            <Separator />

            <!-- Navigation Buttons -->
            <Button fx:id="btnDashboard"  text="⊞  Dashboard"  styleClass="nav-button,active"
                    onAction="#handleNavDashboard"  maxWidth="Infinity" />
            <Button fx:id="btnNotes"      text="📝  Notes"      styleClass="nav-button"
                    onAction="#handleNavNotes"       maxWidth="Infinity" />
            <Button fx:id="btnTasks"      text="✓  Tasks"       styleClass="nav-button"
                    onAction="#handleNavTasks"       maxWidth="Infinity" />
            <Button fx:id="btnReminders"  text="🔔  Reminders"  styleClass="nav-button"
                    onAction="#handleNavReminders"   maxWidth="Infinity" />

            <!-- Spacer pushes Settings to the bottom -->
            <Region VBox.vgrow="ALWAYS" />

            <Separator />
            <Button fx:id="btnSettings" text="⚙  Settings" styleClass="nav-button"
                    onAction="#handleNavSettings" maxWidth="Infinity" />
            <VBox.margin>
                <Insets bottom="12"/>
            </VBox.margin>

        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════════════════
         TOP — Search / Filter / New-Entry Bar
         ══════════════════════════════════════════════════════════ -->
    <top>
        <HBox id="topBar" spacing="12" alignment="CENTER_LEFT">

            <!-- Search -->
            <TextField fx:id="searchField"
                       id="searchField"
                       promptText="🔍  Search entries…"
                       HBox.hgrow="NEVER" />

            <!-- Type filter -->
            <ComboBox fx:id="filterCombo"
                      id="filterCombo"
                      promptText="All Types" />

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- New entry button -->
            <Button fx:id="btnNewEntry"
                    text="＋  New Entry"
                    styleClass="btn-primary"
                    onAction="#handleNewEntry" />

        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════
         CENTER — Dynamic Content Area
         Replaced at runtime by DashboardController when navigating
         ══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fx:id="mainScrollPane"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    id="contentArea">

            <!-- Default home content: summary cards + recent list -->
            <VBox fx:id="homeContent" spacing="20" style="-fx-padding: 24;">

                <!-- Section: Summary Cards -->
                <Label text="Overview" styleClass="section-title" />

                <HBox spacing="16">

                    <VBox styleClass="summary-card,card-notes" HBox.hgrow="ALWAYS" spacing="4">
                        <Label fx:id="countNotes"    text="0" styleClass="card-number" />
                        <Label text="Total Notes"             styleClass="card-label"  />
                    </VBox>

                    <VBox styleClass="summary-card,card-tasks" HBox.hgrow="ALWAYS" spacing="4">
                        <Label fx:id="countTasks"    text="0" styleClass="card-number" />
                        <Label text="Pending Tasks"           styleClass="card-label"  />
                    </VBox>

                    <VBox styleClass="summary-card,card-reminder" HBox.hgrow="ALWAYS" spacing="4">
                        <Label fx:id="countReminders" text="0" styleClass="card-number" />
                        <Label text="Upcoming Reminders"      styleClass="card-label"  />
                    </VBox>

                    <VBox styleClass="summary-card,card-done" HBox.hgrow="ALWAYS" spacing="4">
                        <Label fx:id="countCompleted" text="0" styleClass="card-number" />
                        <Label text="Completed Today"         styleClass="card-label"  />
                    </VBox>

                </HBox>

                <!-- Section: Recent Entries -->
                <Label text="Recent Entries" styleClass="section-title" />

                <!-- Cards are added dynamically by DashboardController -->
                <VBox fx:id="recentEntriesBox" spacing="10" />

                <!-- Shown when no entries / search finds nothing -->
                <Label fx:id="emptyStateLabel"
                       text="No entries found. Try a different search."
                       styleClass="empty-state-label"
                       visible="false"
                       managed="false"
                       maxWidth="Infinity"
                       alignment="CENTER" />

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
